# Copy this file to .env locally and fill in real values.
# NEVER commit the real .env file — it's already in .gitignore.
# On Render, set these under your service's "Environment" tab instead of
# uploading a .env file.

# Postgres connection string (e.g. from Supabase, Render Postgres, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database

# Cloudinary credentials (Dashboard -> your account -> API Keys)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: override the lecturer PIN (defaults to 90435 if not set)
LECTURER_PIN=choose-a-strong-pin

# Required in production: a long, random value used to sign lecturer sessions.
LECTURER_SESSION_SECRET=replace-with-a-long-random-secret
