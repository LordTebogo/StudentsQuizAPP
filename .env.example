# Copy this file to .env locally and fill in real values.
# NEVER commit the real .env file — it's already in .gitignore.
# On Render, set these under your service's "Environment" tab instead of
# uploading a .env file.

# Postgres connection string (e.g. from Supabase, Render Postgres, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database

# Cloudinary credentials (Dashboard -> your account -> API Keys)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Google Maps location picker for Campus Market listings.
# Enable the Maps JavaScript API and restrict this browser key to your app's domain.
GOOGLE_MAPS_API_KEY=your-google-maps-browser-api-key

# Optional: override the lecturer PIN (defaults to 90435 if not set)
LECTURER_PIN=choose-a-strong-pin

# Required in production: a long, random value used to sign lecturer sessions.
LECTURER_SESSION_SECRET=ZrETdNuHEpn6bzDjYG9hdpsa1ebTCmXpQ95ZJw5p7a1FkD60rik947X2DbW8J2V3

# Required in production: a separate long, random value used to sign student sessions.
STUDENT_SESSION_SECRET=l7B07ZPkXkavPGqXroiTVhAGK_c3qlZNTrMXgdAJt22NvJtN-M2PVpkXhes19sUX

# Web Push notifications for installed student apps.
# Generate VAPID keys once, then add the same values in Render's Environment tab.
# The public key is sent to browsers; the private key must stay secret.
VAPID_PUBLIC_KEY=your-base64url-vapid-public-key
VAPID_PRIVATE_KEY=your-base64url-vapid-private-key
VAPID_SUBJECT=mailto:admin@your-institution.example
